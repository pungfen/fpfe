{
  "compilerOptions": {
    "moduleDetection": "force",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "exactOptionalPropertyTypes": true,
    // 大多数非库项目不需要生成声明。 因此我们默认添加此选项以使配置对大多数项目更友好。
    "noEmit": true,
  }
}
