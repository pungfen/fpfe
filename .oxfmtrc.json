{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "trailingComma": "none",
  "ignorePatterns": [
    "dist"
  ],
  "sortImports": {
    "partitionByNewline": true,
    "newlinesBetween": false
  },
  "sortTailwindcss": {},
  "sortPackageJson": {
    "sortScripts": true
  },
  "insertFinalNewline": false,
  "vueIndentScriptAndStyle": true
}